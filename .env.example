# ============================================================
# AGENTE DE VIDEOS HISTÓRICOS — Variables de entorno
# Copia este archivo como .env y rellena cada valor
# NUNCA subas .env a GitHub
# ============================================================

# ------------------------------------------------------------
# CLAUDE / ANTHROPIC
# Obtén tu key en: https://console.anthropic.com/
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------
# AZURE TEXT TO SPEECH
# Crea cuenta gratis en: https://portal.azure.com/
# Servicio: "Speech" → crea recurso → copia Key 1 y Region
# Región recomendada: westeurope (más cercana a Portugal)
# ------------------------------------------------------------
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=westeurope

# ------------------------------------------------------------
# REPLICATE (imágenes FLUX)
# Obtén token en: https://replicate.com/account/api-tokens
# ------------------------------------------------------------
REPLICATE_API_TOKEN=r8_...

# ------------------------------------------------------------
# HAILUO / MINIMAX (animación — opcional en Fase inicial)
# ------------------------------------------------------------
HAILUO_API_KEY=

# ------------------------------------------------------------
# GOOGLE SHEETS + YOUTUBE
# Sigue la guía en README para obtener credentials.json
# El Spreadsheet ID está en la URL de tu Google Sheet:
# https://docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit
# ------------------------------------------------------------
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=

# ------------------------------------------------------------
# YOUTUBE DATA API v3
# Mismo proyecto de Google Cloud que Sheets
# ------------------------------------------------------------
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ------------------------------------------------------------
# TELEGRAM (notificaciones)
# Crea bot: habla con @BotFather en Telegram → /newbot
# Chat ID: habla con @userinfobot para obtener tu ID
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ------------------------------------------------------------
# ARTLIST (música — descarga manual por ahora)
# Coloca los .mp3 de Artlist en: output/musica/
# ------------------------------------------------------------
ARTLIST_MUSIC_FOLDER=output/musica

# ------------------------------------------------------------
# CONFIGURACIÓN DEL CANAL
# ------------------------------------------------------------
CHANNEL_NAME=NombreDeTuCanal

# Categoría YouTube: 27 = Educación, 22 = Entretenimiento
YOUTUBE_CATEGORY_ID=27

# Hora de publicación en YouTube (hora de Madrid)
PUBLISH_TIME=18:30
PUBLISH_TIMEZONE=Europe/Madrid

# Cuántos videos largos por semana
VIDEOS_PER_WEEK=3

# Días de publicación (0=lunes ... 6=domingo), separados por coma
PUBLISH_DAYS=0,1,2,3,4
